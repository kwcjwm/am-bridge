{
  "tools": [
    {
      "name": "am-bridge-stage",
      "description": "Run a requested am-bridge stage for one legacy page and return JSON summary plus artifact paths.",
      "command": "python",
      "args": [
        "<REPO_ROOT>/scripts/ai_pro_stage_runner.py",
        "{stage}",
        "{page_xml}",
        "--config",
        "<REPO_ROOT>/am-bridge.config.json"
      ],
      "parameters": {
        "stage": {
          "type": "string",
          "enum": [
            "stage1",
            "stage2",
            "stage3"
          ]
        },
        "page_xml": {
          "type": "string"
        }
      }
    }
  ]
}
